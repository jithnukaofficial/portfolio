# Fix line endings for Linux scripts (important for shell scripts on Droplet)
* text=auto
*.sh text eol=lf
*.conf text eol=lf
Containerfile text eol=lf
Jenkinsfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
